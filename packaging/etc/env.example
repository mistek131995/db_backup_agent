# Backupster Agent — environment file
# Read by systemd unit /usr/lib/systemd/system/backupster-agent.service
# After editing, restart the service: systemctl restart backupster-agent

# Agent token issued at https://app.backupster.io
# AgentSettings__Token=

# Dashboard URL — change only for self-hosted installations
AgentSettings__DashboardUrl=https://app.backupster.io
